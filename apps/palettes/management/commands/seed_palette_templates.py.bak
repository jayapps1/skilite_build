class Command(BaseCommand):
    help = (
        "Seeds public preset palettes and light/dark "
        "recommendation-template palettes."
    )

    requires_migrations_checks = True

    @transaction.atomic
    def handle(self, *args, **options):
        self.stdout.write(
            self.style.MIGRATE_HEADING(
                "Seeding preset and recommendation-template palettes..."
            )
        )

        palette_counts = {
            "created": 0,
            "updated": 0,
        }

        color_counts = {
            "created": 0,
            "updated": 0,
        }

        for blueprint in PALETTE_BLUEPRINTS:
            category = self.get_category(
                blueprint["category_slug"]
            )

            dominant_family = self.get_color_family(
                blueprint["dominant_family_slug"]
            )

            variants = [
                {
                    "slug": (
                        f"system-preset-"
                        f"{blueprint['category_slug']}-light"
                    ),
                    "name": (
                        f"{category.name} Professional Light"
                    ),
                    "description": (
                        f"A professional light preset palette for "
                        f"{category.name.lower()} websites."
                    ),
                    "source_type": PaletteSource.PRESET,
                    "theme_mode": ThemeMode.LIGHT,
                    "visibility": PaletteVisibility.PUBLIC,
                    "allow_export": True,
                    "is_published": True,
                    "colors": blueprint["light"],
                },
                {
                    "slug": (
                        f"system-template-"
                        f"{blueprint['category_slug']}-light"
                    ),
                    "name": (
                        f"{category.name} Recommendation Template Light"
                    ),
                    "description": (
                        f"System light recommendation template for "
                        f"{category.name.lower()} businesses."
                    ),
                    "source_type": (
                        PaletteSource.RECOMMENDATION_TEMPLATE
                    ),
                    "theme_mode": ThemeMode.LIGHT,
                    "visibility": PaletteVisibility.UNLISTED,
                    "allow_export": False,
                    "is_published": False,
                    "colors": blueprint["light"],
                },
                {
                    "slug": (
                        f"system-template-"
                        f"{blueprint['category_slug']}-dark"
                    ),
                    "name": (
                        f"{category.name} Recommendation Template Dark"
                    ),
                    "description": (
                        f"System dark recommendation template for "
                        f"{category.name.lower()} businesses."
                    ),
                    "source_type": (
                        PaletteSource.RECOMMENDATION_TEMPLATE
                    ),
                    "theme_mode": ThemeMode.DARK,
                    "visibility": PaletteVisibility.UNLISTED,
                    "allow_export": False,
                    "is_published": False,
                    "colors": blueprint["dark"],
                },
            ]

            for variant in variants:
                palette_created, current_color_counts = (
                    self.upsert_palette(
                        category=category,
                        dominant_family=dominant_family,
                        variant=variant,
                    )
                )

                if palette_created:
                    palette_counts["created"] += 1
                else:
                    palette_counts["updated"] += 1

                color_counts["created"] += (
                    current_color_counts["created"]
                )

                color_counts["updated"] += (
                    current_color_counts["updated"]
                )

        self.stdout.write("")
        self.stdout.write(
            self.style.SUCCESS(
                "Preset and recommendation-template palettes "
                "seeded successfully."
            )
        )

        self.stdout.write(
            f"Palettes: {palette_counts['created']} created, "
            f"{palette_counts['updated']} updated."
        )

        self.stdout.write(
            f"Palette colours: {color_counts['created']} created, "
            f"{color_counts['updated']} updated."
        )

    def upsert_palette(
        self,
        category,
        dominant_family,
        variant,
    ):
        colors = variant["colors"]

        self.validate_color_map(
            palette_name=variant["name"],
            colors=colors,
        )

        palette, palette_created = (
            Palette.objects.update_or_create(
                slug=variant["slug"],
                defaults={
                    "owner": None,
                    "business_category": category,
                    "dominant_color_family": dominant_family,
                    "source_palette": None,
                    "name": variant["name"],
                    "description": variant["description"],
                    "source_type": variant["source_type"],
                    "theme_mode": variant["theme_mode"],
                    "visibility": variant["visibility"],
                    "moderation_status": (
                        ModerationStatus.APPROVED
                    ),
                    "allow_export": variant["allow_export"],
                    "is_published": variant["is_published"],
                    "is_featured": False,
                    "is_active": True,
                },
            )
        )

        color_counts = {
            "created": 0,
            "updated": 0,
        }

        expected_roles = set(ColorRole.values)

        PaletteColor.objects.filter(
            palette=palette,
        ).exclude(
            role__in=expected_roles,
        ).delete()

        for role in ColorRole.values:
            _, color_created = (
                PaletteColor.objects.update_or_create(
                    palette=palette,
                    role=role,
                    defaults={
                        "hex_value": colors[role],
                    },
                )
            )

            if color_created:
                color_counts["created"] += 1
            else:
                color_counts["updated"] += 1

        actual_roles = set(
            PaletteColor.objects.filter(
                palette=palette,
            ).values_list(
                "role",
                flat=True,
            )
        )

        if actual_roles != expected_roles:
            missing_roles = sorted(
                expected_roles - actual_roles
            )

            extra_roles = sorted(
                actual_roles - expected_roles
            )

            raise CommandError(
                f"Palette '{palette.name}' does not have the "
                f"complete semantic colour system. "
                f"Missing: {missing_roles}. Extra: {extra_roles}."
            )

        return palette_created, color_counts

    def validate_color_map(self, palette_name, colors):
        expected_roles = set(ColorRole.values)
        supplied_roles = set(colors.keys())

        missing_roles = sorted(
            expected_roles - supplied_roles
        )

        extra_roles = sorted(
            supplied_roles - expected_roles
        )

        if missing_roles or extra_roles:
            raise CommandError(
                f"Invalid colour map for '{palette_name}'. "
                f"Missing roles: {missing_roles}. "
                f"Unexpected roles: {extra_roles}."
            )

    def get_category(self, slug):
        try:
            return BusinessCategory.objects.get(
                slug=slug,
                is_active=True,
            )
        except BusinessCategory.DoesNotExist as exc:
            raise CommandError(
                f"Missing active business category '{slug}'. "
                "Run: python manage.py seed_reference_data"
            ) from exc

    def get_color_family(self, slug):
        try:
            return ColorFamily.objects.get(
                slug=slug,
                is_active=True,
            )
        except ColorFamily.DoesNotExist as exc:
            raise CommandError(
                f"Missing active colour family '{slug}'. "
                "Run: python manage.py seed_reference_data"
            ) from exc
